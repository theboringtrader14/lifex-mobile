{
  "expo": {
    "name": "LIFEX",
    "slug": "lifex-mobile",
    "scheme": "lifex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#E8EEF6",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8EEF6"
    },
    "ios": {
      "bundleIdentifier": "com.lifexos.mobile",
      "supportsTablet": false
    },
    "android": {
      "package": "com.lifexos.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8EEF6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0917e823-83bc-45ff-9dbb-a501ed0ea9bd"
      }
    },
    "owner": "bjkarthi"
  }
}
